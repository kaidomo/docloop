#!/usr/bin/env bash
# docloop — a thin writing harness.
#
# It does NOT add a runtime or an agent. It wraps the model CLI you already use
# (codex or claude -p) and feeds it docloop's stage prompts + your work-folder
# context. The IP is the prompts (prompts/), the scripts (lib/), and the loop
# discipline — not this launcher.
#
# Model: set DOCLOOP_MODEL=codex (default) or DOCLOOP_MODEL=claude.
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROMPTS="$ROOT/prompts"
LIB="$ROOT/lib"
MODEL="${DOCLOOP_MODEL:-codex}"

die() { echo "docloop: $*" >&2; exit 1; }

# run_model <prompt-text> <rw|ro>
# Feeds the assembled prompt to the configured model CLI, in the current folder.
run_model() {
  local prompt="$1" mode="${2:-rw}"
  case "$MODEL" in
    codex)
      if [ "$mode" = "ro" ]; then
        codex exec --skip-git-repo-check --sandbox read-only "$prompt"
      else
        codex exec --skip-git-repo-check "$prompt"
      fi ;;
    claude)
      # claude -p runs headless; permissions are governed by the user's settings.
      claude -p "$prompt" ;;
    *) die "unknown DOCLOOP_MODEL '$MODEL' (use codex or claude)" ;;
  esac
}

# stage_prompt <stage-file> <extra user text...>
# Assemble: the stage prompt + work-folder context + the user's request.
stage_prompt() {
  local file="$PROMPTS/$1"; shift
  [ -f "$file" ] || die "no such stage prompt: $file"
  cat "$file"
  printf '\n\n---\n## Run context\n'
  printf -- '- Work folder: %s\n' "$PWD"
  printf -- '- docloop lib (scripts): %s\n' "$LIB"
  [ -f "$PWD/manifest.yaml" ] && printf -- '- Manifest: %s/manifest.yaml\n' "$PWD"
  [ "$#" -gt 0 ] && printf -- '- User request: %s\n' "$*"
}

usage() {
  cat <<EOF
docloop — a thin writing harness (wraps codex / claude -p)

  docloop init <folder> [inputs...]   scaffold a work folder (inputs/ work/ outputs/ reports/)
  docloop plan   [request...]         vague ask -> structured manifest (intake interview)
  docloop draft  [notes...]           write sections from evidence (reconcile)
  docloop audit                       gap-audit: find contradictions (fan-out) + report
  docloop review <name> <target...>   the Oracle loop: external-model cross-review
  docloop panel <folder> <N> [roles]  role-panel review: independent job-role evaluators (per-process isolation) + Area Chair synthesis
  docloop lock <payload-file>         seal a prediction (sha256 sidecar) BEFORE the outcome exists
  docloop verify <payload> <sidecar>  re-hash the payload; mismatch = judge nothing (diagnostic-only)
  docloop split  [manifest.yaml]      regenerate publish pages from the SSOT
  docloop gate   [manifest.yaml] [--strict-cross-audit]   release gate (gap_audit.py --strict)

Change-plan mode (as-is/to-be) — plan fixes to an existing system, for a human to apply:
  docloop atb-capture [sources...]    read the system -> capture observations (issues)
  docloop atb-chunk                   group observations into chunks + sequence (handoff)
  docloop atb-author                  write the as-is/to-be body per chunk into the SSOT
  docloop atb-audit                   ground-audit: verify each as-is against its evidence (fan-out)
  docloop atb-gate [manifest.yaml] [--strict-cross-audit]   handoff gate (ground_audit.py --strict)
  (reuses: docloop init, docloop review)

Env: DOCLOOP_MODEL=codex|claude (default codex)   DOCLOOP_REVIEW_DIR=~/.docloop/reviews
Run plan/draft/audit (and atb-*) from inside the work folder.
EOF
}

cmd="${1:-}"; shift || true
case "$cmd" in
  init)
    [ "$#" -ge 1 ] || die "usage: docloop init <folder> [inputs...]"
    python3 "$LIB/init_workspace.py" "$@" ;;
  plan)   run_model "$(stage_prompt plan.md "$@")"  rw ;;
  draft)  run_model "$(stage_prompt draft.md "$@")" rw ;;
  audit)  run_model "$(stage_prompt gap-audit.md "$@")" rw ;;
  review)
    [ "$#" -ge 2 ] || die "usage: docloop review <name> <target...>"
    name="$1"; shift
    python3 "$LIB/stage.py" "$name" "$@"
    echo "docloop: review folder staged. Now fill REVIEW_BRIEF.md, then follow prompts/review.md." ;;
  panel)
    [ "$#" -ge 2 ] || die "usage: docloop panel <review-folder> <roundN> [roles...]"
    bash "$LIB/panel_review.sh" "$@" ;;
  lock)
    [ "$#" -ge 1 ] || die "usage: docloop lock <payload-file> [--locker NAME]"
    python3 "$LIB/blind_lock.py" lock "$@" ;;
  verify)
    [ "$#" -eq 2 ] || die "usage: docloop verify <payload-file> <sidecar>"
    python3 "$LIB/blind_lock.py" verify "$@" ;;
  split)  python3 "$LIB/split.py" "${1:-manifest.yaml}" ;;
  gate)
    # Optional leading manifest path; remaining args (e.g. --strict-cross-audit) pass through.
    mf="manifest.yaml"
    if [ "${1:-}" ] && [ "${1#-}" = "$1" ]; then mf="$1"; shift; fi
    python3 "$LIB/gap_audit.py" "$mf" --strict "$@" ;;
  # ── change-plan mode (as-is/to-be) ──
  atb-capture) run_model "$(stage_prompt atb-capture.md "$@")" rw ;;
  atb-chunk)   run_model "$(stage_prompt atb-chunk.md "$@")"   rw ;;
  atb-author)  run_model "$(stage_prompt atb-author.md "$@")"  rw ;;
  atb-audit)   run_model "$(stage_prompt atb-audit.md "$@")"   rw ;;
  atb-gate)
    mf="manifest.yaml"
    if [ "${1:-}" ] && [ "${1#-}" = "$1" ]; then mf="$1"; shift; fi
    python3 "$LIB/ground_audit.py" "$mf" --strict "$@" ;;
  ""|-h|--help|help) usage ;;
  *) die "unknown command '$cmd' (try: docloop --help)" ;;
esac
